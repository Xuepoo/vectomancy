<!DOCTYPE html>
<html>
<head>
    <title>Vectomancy Desmos Export - {{ base_name }}</title>
    <script src="https://www.desmos.com/api/v1.9/calculator.js?apiKey=dcb31709b452b1cf9dc26972add0fda6"></script>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; }
        #calculator { width: 100%; height: 100%; }
    </style>
</head>
<body>
    <div id="calculator"></div>
    <script>
        var elt = document.getElementById('calculator');
        var calculator = Desmos.GraphingCalculator(elt, {
            expressions: true,
            settingsMenu: true,
            zoomButtons: true
        });

        var expressions = [];
        var exprId = 1;

        {% if equations %}
        {% for path in equations %}
        expressions.push({
            id: String(exprId++),
            latex: '\\left(' +
                '\\left\\{ ' +
                '{% for eq in path.data %}' +
                '{% set eq_index = loop.index0 %}' +
                '{{ eq_index }} \\le t < {{ loop.index }}: ' +
                '{% for c in eq.x_poly %}{{ c }}{% if loop.index0 == 1 %}*(t-{{ eq_index }}){% elif loop.index0 > 1 %}*(t-{{ eq_index }})^{{ loop.index0 }}{% endif %}{% if not loop.last %} + {% endif %}{% endfor %}' +
                '{% if not loop.last %}, {% endif %}' +
                '{% endfor %}' +
                ' \\right\\}, ' +
                '{{ height }} - \\left( \\left\\{ ' +
                '{% for eq in path.data %}' +
                '{% set eq_index = loop.index0 %}' +
                '{{ eq_index }} \\le t < {{ loop.index }}: ' +
                '{% for c in eq.y_poly %}{{ c }}{% if loop.index0 == 1 %}*(t-{{ eq_index }}){% elif loop.index0 > 1 %}*(t-{{ eq_index }})^{{ loop.index0 }}{% endif %}{% if not loop.last %} + {% endif %}{% endfor %}' +
                '{% if not loop.last %}, {% endif %}' +
                '{% endfor %}' +
                ' \\right\\} \\right)' +
                '\\right)',
            parametricDomain: {min: '0', max: '{{ path.data | length }}'},
            color: '{% if path.color_rgb %}rgb({{ path.color_rgb.0 }}, {{ path.color_rgb.1 }}, {{ path.color_rgb.2 }}){% else %}rgb(0,0,0){% endif %}'
        });
        {% endfor %}
        {% elif strokes %}
        {% for stroke_path in strokes %}
        expressions.push({
            id: String(exprId++),
            latex: '\\left(' +
                '{% for term in stroke_path.data %}{% if not loop.first %} + {% endif %}{{ term.amplitude }}*\\cos({{ term.frequency }}*t + {{ term.phase }}){% endfor %}' +
                '{% if stroke_path.data | length == 0 %}0{% endif %}' +
                ', ' +
                '{{ height }} - \\left(' +
                '{% for term in stroke_path.data %}{% if not loop.first %} + {% endif %}{{ term.amplitude }}*\\sin({{ term.frequency }}*t + {{ term.phase }}){% endfor %}' +
                '{% if stroke_path.data | length == 0 %}0{% endif %}' +
                '\\right)\\right)',
            parametricDomain: {min: '0', max: '6.28318530718'},
            color: '{% if stroke_path.color_rgb %}rgb({{ stroke_path.color_rgb.0 }}, {{ stroke_path.color_rgb.1 }}, {{ stroke_path.color_rgb.2 }}){% else %}rgb(0,0,0){% endif %}'
        });
        {% endfor %}
        {% elif paths %}
        {% for path in paths %}
        expressions.push({
            id: String(exprId++),
            latex: '\\left[ {% for p in path.data %}\\left({{ p.x }}, {{ height }} - {{ p.y }}\\right){% if not loop.last %},{% endif %}{% endfor %} \\right]',
            color: '{% if path.color_rgb %}rgb({{ path.color_rgb.0 }}, {{ path.color_rgb.1 }}, {{ path.color_rgb.2 }}){% else %}rgb(0,0,0){% endif %}',
            lines: true,
            points: false
        });
        {% endfor %}
        {% endif %}

        var batchSize = 50;
        var currentIndex = 0;
        var loadingDiv = document.createElement('div');
        loadingDiv.style.position = 'absolute';
        loadingDiv.style.top = '10px';
        loadingDiv.style.left = '10px';
        loadingDiv.style.background = 'rgba(0, 0, 0, 0.7)';
        loadingDiv.style.color = 'white';
        loadingDiv.style.padding = '10px 20px';
        loadingDiv.style.borderRadius = '5px';
        loadingDiv.style.fontFamily = 'sans-serif';
        loadingDiv.style.zIndex = '1000';
        document.body.appendChild(loadingDiv);

        function loadBatch() {
            var batch = expressions.slice(currentIndex, currentIndex + batchSize);
            if (batch.length > 0) {
                // Upsert expressions into Desmos
                calculator.setExpressions(batch);
                currentIndex += batchSize;
                var progress = Math.min(100, Math.round((currentIndex / expressions.length) * 100));
                loadingDiv.innerText = 'Loading expressions: ' + progress + '% (' + currentIndex + ' / ' + expressions.length + ')';
                // Yield to the browser thread to prevent freezing
                setTimeout(loadBatch, 50);
            } else {
                loadingDiv.innerText = 'Loading complete!';
                setTimeout(function() {
                    loadingDiv.style.display = 'none';
                }, 2000);
            }
        }

        loadBatch();
    </script>
</body>
</html>
